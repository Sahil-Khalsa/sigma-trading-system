# Alpaca (get from alpaca.markets — use paper trading keys)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Polygon.io (get from polygon.io — free tier works)
POLYGON_API_KEY=your_polygon_api_key

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# PostgreSQL
DATABASE_URL=postgresql://sigma:sigma_pass@localhost:5432/sigma_db

# Redis
REDIS_URL=redis://localhost:6379

# App
APP_ENV=development
LOG_LEVEL=INFO

# Trading config
WATCHLIST=AAPL,MSFT,NVDA,TSLA,AMZN
MAX_POSITION_SIZE_PCT=0.10
MAX_DAILY_LOSS_PCT=0.02
MIN_CONFIDENCE_THRESHOLD=0.70
MAX_AGENT_ITERATIONS=7
